# ─── Quovex Backend — Environment Variables ─────────────────────────────────
# Copy this file to .env and fill in all values before running.
# NEVER commit .env to git.

# ── Application ───────────────────────────────────────────────────────────────
ENVIRONMENT=production                 # development | production
SECRET_KEY=change-me-to-a-random-64-char-string-generated-with-openssl-rand-hex-32

# ── Database ──────────────────────────────────────────────────────────────────
# Production (PostgreSQL)
DATABASE_URL=postgresql://quovex:STRONG_PASSWORD@localhost:5432/quovex
# Development (SQLite — no setup required)
# DATABASE_URL=sqlite:///./studytimer.db

# PostgreSQL credentials (used by docker-compose.prod.yml)
POSTGRES_USER=quovex
POSTGRES_PASSWORD=STRONG_PASSWORD_HERE
POSTGRES_DB=quovex

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=                        # Set a password in production
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Firebase ──────────────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=quovex-84b14
# Option A: firebase-credentials.json already in project root
FIREBASE_CREDENTIALS_PATH=firebase-credentials.json

# Option B: Paste the full JSON as a single-line env var (no file on disk)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"quovex-84b14",...}

# ── Email (Gmail SMTP for OTPs) ───────────────────────────────────────────────
# Generate an App Password from Google Account → Security → 2-Step Verification → App Passwords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=supportquovex@gmail.com
EMAIL_PASS=<your-gmail-app-password>
FROM_EMAIL=supportquovex@gmail.com

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["https://admin.quovex.online","https://quovex.online"]

# ── Cerebras (AI Quiz Generation) ─────────────────────────────────────────────
CEREBRAS_API_KEY=your-cerebras-api-key
CEREBRAS_MODEL=llama3.1-8b-instruct

# ── Business Rules ────────────────────────────────────────────────────────────
REWARD_BUDGET_CAP_PERCENT=35
BASE_POINTS_PER_HOUR=100
DIMINISHING_RETURNS_AFTER_HOURS=6
MAX_DAILY_HOURS_FLAG=12
SOCIAL_UNLOCK_MINUTES_PER_HOUR=15
QUIZ_SET_SIZE=10
QUIZ_QUESTION_TIME_LIMIT_SECONDS=25
MAX_QUIZ_ATTEMPTS_PER_SUBJECT_PER_DAY=5
