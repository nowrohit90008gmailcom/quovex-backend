[Unit]
Description=Quovex Dashboard (Next.js)
After=network.target
StartLimitIntervalSec=30

[Service]
Type=simple
User=quovex
Group=quovex
WorkingDirectory=/opt/quovex/dashboard
Environment=NODE_ENV=production
Environment=NEXT_PUBLIC_API_URL=https://api.quovex.online/api/v1
ExecStart=/usr/bin/node /opt/quovex/dashboard/server.js
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
