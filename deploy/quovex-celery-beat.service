[Unit]
Description=Quovex Celery Beat Scheduler
After=network.target redis-server.service
Requires=redis-server.service
StartLimitIntervalSec=30

[Service]
Type=simple
User=quovex
Group=quovex
WorkingDirectory=/opt/quovex
EnvironmentFile=/opt/quovex/.env
ExecStart=/opt/quovex/venv/bin/celery -A app.tasks.celery_app beat --loglevel=info
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
